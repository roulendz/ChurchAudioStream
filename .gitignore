# Dependencies
node_modules/

# Build output
dist/
target/
sidecar/public/

# Test coverage output (vitest --coverage)
coverage/

# Tauri generated files
src-tauri/gen/

# Compiled sidecar binaries
src-tauri/binaries/

# Runtime config (not source)
config.json

# TLS certificates
*.pem

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Environment files
.env
.env.local

# TypeScript incremental build cache
*.tsbuildinfo

# Playwright / test runner artifacts
test-results/
playwright-report/

# Runtime logs (dev fallback path; persistent logs live in %APPDATA%)
src-tauri/logs/

# Local test fixtures (large media files, often licensed)
src-tauri/test-media/

# Claude Code agent session state
.claude/
