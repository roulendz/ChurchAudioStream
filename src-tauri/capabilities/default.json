{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Main window capabilities for sidecar management and core features",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "process:default",
    "updater:default"
  ]
}
